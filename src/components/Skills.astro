---
import { skills } from '../data/skills';
---

<section class="section" id="skills">
  <div class="container">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      {
        skills.map((group) => (
          <div class="skill-group">
            <h3>{group.category}</h3>
            <ul class="tags">
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
