---
import { skills } from '../data/skills';
---

<section class="section" id="skills">
  <div class="container">
    <h2 class="section-title">Skills</h2>
    <dl class="skills-list">
      {
        skills.map((group) => (
          <div class="skills-row">
            <dt>{group.category}</dt>
            <dd>{group.items.join(' · ')}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
